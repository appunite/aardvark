{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.aardvark.dev/schemas/bundle-manifest-1.0.json",
  "title": "Aardvark Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "entrypoint"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^[^:]+:[^:]+$",
      "description": "Entry point in module:function form."
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pyodide": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "version": { "type": "string" }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultLimitMs": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true,
              "default": []
            },
            "httpsOnly": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["read", "readWrite"]
            },
            "quotaBytes": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "hostCapabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        }
      }
    }
  }
}
