{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.aardvark.dev/schemas/bundle-manifest-1.0.json",
  "title": "Aardvark Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "entrypoint"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^[^:]+:[^:]+$",
      "description": "Entry point in module:function form."
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "default": []
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string",
          "enum": ["python", "javascript"],
          "description": "Guest language runtime to load. Defaults to python."
        },
        "pyodide": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "version": { "type": "string" },
            "profile": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+$",
              "description": "Host-defined Pyodide distribution profile, selected before isolate creation."
            },
            "preloadImports": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true,
              "default": [],
              "description": "Python module names imported immediately before warm-state snapshot capture. Use only for modules that are safe to restore from Pyodide snapshots."
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultLimitMs": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true,
              "default": []
            },
            "httpsOnly": {
              "type": "boolean",
              "default": true
            },
            "maxRequestBytes": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum native fetch request body size in bytes."
            },
            "maxResponseBytes": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum native fetch response body size in bytes."
            },
            "timeoutMs": {
              "type": "integer",
              "minimum": 1,
              "description": "Per-request native fetch timeout in milliseconds."
            }
          }
        },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["read", "readWrite"]
            },
            "quotaBytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "hostCapabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime": {
            "properties": {
              "language": { "const": "javascript" }
            },
            "required": ["language"]
          }
        },
        "required": ["runtime"]
      },
      "then": {
        "properties": {
          "packages": { "maxItems": 0 },
          "runtime": {
            "not": {
              "required": ["pyodide"]
            }
          }
        }
      }
    }
  ]
}
